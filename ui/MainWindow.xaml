<Window x:Class="VRAMOptimizer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="VRAM Optimizer" Height="780" Width="1100"
        MinHeight="680" MinWidth="900"
        Background="{StaticResource BrBgDark}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Topbar -->
            <RowDefinition Height="*"/>    <!-- Conteúdo -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             TOPBAR
        ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BrBgPanel}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + título -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="▣" FontSize="20" Foreground="{StaticResource BrAccent}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="VRAM Optimizer" FontSize="16"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="  v1.0" FontSize="11"
                               Foreground="{StaticResource BrTextSec}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Status do hook (centro) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="EllipseHookStatus" Width="8" Height="8"
                             Fill="{StaticResource BrTextSec}" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TxtHookStatus" Text="Aguardando hook..."
                               Foreground="{StaticResource BrTextSec}" FontSize="12"/>
                </StackPanel>

                <!-- Backend VRAM (direita) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TxtBackend" Text="Backend: --"
                               Foreground="{StaticResource BrTextSec}" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             CONTEÚDO PRINCIPAL
        ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>        <!-- Painel esquerdo -->
                <ColumnDefinition Width="12"/>         <!-- Espaço -->
                <ColumnDefinition Width="*"/>          <!-- Painel direito -->
            </Grid.ColumnDefinitions>

            <!-- ── COLUNA ESQUERDA ──────────────────────────────────── -->
            <StackPanel Grid.Column="0">

                <!-- Card: VRAM -->
                <Border Background="{StaticResource BrBgCard}"
                        CornerRadius="10" Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="MEMÓRIA DE VÍDEO" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,10"/>

                        <!-- Valores numéricos -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtVRAMUsed" Text="-- MB / -- MB"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource BrAccent}"/>
                            <TextBlock x:Name="TxtVRAMPct" Text="--%"
                                       Grid.Column="1" FontSize="22" FontWeight="Bold"
                                       VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- Barra de progresso customizada -->
                        <Border Height="14" CornerRadius="7"
                                Background="{StaticResource BrBgDark}">
                            <Border x:Name="VRAMBar" HorizontalAlignment="Left"
                                    Height="14" CornerRadius="7" Width="0"
                                    MinWidth="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{StaticResource Accent}"   Offset="0"/>
                                        <GradientStop Color="{StaticResource AccentHover}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>

                        <!-- Linha de livre/total -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource BrTextSec}" FontSize="11">
                                <Run Text="Livre: "/>
                                <Run x:Name="RunFree" Text="-- MB"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1"
                                       Foreground="{StaticResource BrTextSec}" FontSize="11">
                                <Run Text="Pico: "/>
                                <Run x:Name="RunPeak" Text="--%"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card: Injeção -->
                <Border Background="{StaticResource BrBgCard}"
                        CornerRadius="10" Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="INJEÇÃO NO JOGO" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Processo (.exe)" FontSize="11"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtProcessName"
                                 Text="eldenring.exe"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Caminho da DLL" FontSize="11"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDllPath" Text="vram_hook.dll"/>
                            <Button Grid.Column="2" Content="..." Width="32"
                                    Style="{StaticResource BtnSecondary}"
                                    Click="BtnBrowseDll_Click"
                                    Padding="4,6" ToolTip="Procurar DLL"/>
                        </Grid>

                        <CheckBox x:Name="ChkWatchMode"
                                  Content="Modo Watch (re-injeta ao reiniciar)"
                                  Margin="0,0,0,12" IsChecked="True"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Injetar" Style="{StaticResource BtnPrimary}"
                                    Click="BtnInject_Click"/>
                            <Button Grid.Column="2" Content="Ejetar"
                                    Style="{StaticResource BtnDanger}"
                                    Click="BtnEject_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card: Estatísticas -->
                <Border Background="{StaticResource BrBgCard}"
                        CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="ESTATÍSTICAS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Texturas" Foreground="{StaticResource BrTextSec}" FontSize="11"/>
                            <TextBlock x:Name="TxtStatTextures" Grid.Column="1"
                                       Text="0 / 0" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Text="Liberado"
                                       Foreground="{StaticResource BrTextSec}" FontSize="11"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="TxtStatSaved" Grid.Row="1" Grid.Column="1"
                                       Text="0 MB" HorizontalAlignment="Right"
                                       Foreground="{StaticResource BrOk}" FontWeight="SemiBold"
                                       Margin="0,6,0,0"/>

                            <TextBlock Grid.Row="2" Text="Ações disparadas"
                                       Foreground="{StaticResource BrTextSec}" FontSize="11"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="TxtStatActions" Grid.Row="2" Grid.Column="1"
                                       Text="0" HorizontalAlignment="Right"
                                       Margin="0,6,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ── COLUNA DIREITA ────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Tabs -->
                    <RowDefinition Height="*"/>      <!-- Conteúdo das tabs -->
                </Grid.RowDefinitions>

                <!-- Tabs -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="TabBtnConfig" Content="Configurações"
                            Style="{StaticResource BtnPrimary}"
                            Margin="0,0,6,0" Click="TabConfig_Click"/>
                    <Button x:Name="TabBtnTextures" Content="Texturas"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,6,0" Click="TabTextures_Click"/>
                    <Button x:Name="TabBtnGraph" Content="Gráfico"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,6,0" Click="TabGraph_Click"/>
                    <Button x:Name="TabBtnLog" Content="Log"
                            Style="{StaticResource BtnSecondary}"
                            Click="TabLog_Click"/>
                </StackPanel>

                <!-- ── TAB: CONFIGURAÇÕES ──────────────────────────── -->
                <ScrollViewer x:Name="PanelConfig" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,4,0">

                        <!-- Limiares de VRAM -->
                        <Border Background="{StaticResource BrBgCard}"
                                CornerRadius="10" Padding="16" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="LIMIARES DE VRAM" FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BrTextSec}"
                                           Margin="0,0,0,14"/>

                                <!-- Aviso -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="⚠ Aviso" Foreground="{StaticResource BrWarn}"/>
                                    </TextBlock>
                                    <Slider x:Name="SliderWarn" Grid.Column="1"
                                            Minimum="50" Maximum="100" Value="70"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblWarn" Grid.Column="2"
                                               Text="70%" TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrWarn}"/>
                                </Grid>

                                <!-- Compressão leve -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Compressão Leve"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="SliderLow" Grid.Column="1"
                                            Minimum="50" Maximum="100" Value="80"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblLow" Grid.Column="2"
                                               Text="80%" TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrAccent}"/>
                                </Grid>

                                <!-- Compressão média -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Compressão Média"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="SliderMed" Grid.Column="1"
                                            Minimum="50" Maximum="100" Value="90"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblMed" Grid.Column="2"
                                               Text="90%" TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrWarn}"/>
                                </Grid>

                                <!-- Emergência -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="🚨 Emergência"
                                             Foreground="{StaticResource BrCrit}"/>
                                    </TextBlock>
                                    <Slider x:Name="SliderEmerg" Grid.Column="1"
                                            Minimum="50" Maximum="100" Value="95"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblEmerg" Grid.Column="2"
                                               Text="95%" TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrCrit}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Compressão -->
                        <Border Background="{StaticResource BrBgCard}"
                                CornerRadius="10" Padding="16" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="COMPRESSÃO" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrTextSec}"
                                           Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Formato preferido"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CboFormat" Grid.Column="1"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="BC1 — RGB, sem alpha (mais rápido)"/>
                                        <ComboBoxItem Content="BC3 — RGBA, com alpha"/>
                                        <ComboBoxItem Content="BC7 — Alta qualidade (requer ISPC)"/>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Texturas por tick"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="SliderMaxTex" Grid.Column="1"
                                            Minimum="1" Maximum="10" Value="4"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblMaxTex" Grid.Column="2"
                                               Text="4" TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrAccent}"/>
                                </Grid>

                                <CheckBox x:Name="ChkAllowHalfRes"
                                          Content="Permitir HalfRes (downscale 50%)"
                                          IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkAllowQuarterRes"
                                          Content="Permitir QuarterRes (só emergência)"
                                          IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkSkipCritical"
                                          Content="Nunca comprimir prioridade Crítica"
                                          IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Monitor -->
                        <Border Background="{StaticResource BrBgCard}"
                                CornerRadius="10" Padding="16">
                            <StackPanel>
                                <TextBlock Text="MONITOR" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrTextSec}"
                                           Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Intervalo de leitura (ms)"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="SliderInterval" Grid.Column="1"
                                            Minimum="100" Maximum="2000" Value="500"
                                            TickFrequency="100" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LblInterval" Grid.Column="2"
                                               Text="500ms" TextAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrAccent}"/>
                                </Grid>

                                <CheckBox x:Name="ChkLogToFile"
                                          Content="Salvar log em arquivo (vram_optimizer.log)"
                                          IsChecked="True" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkAutoStart"
                                          Content="Iniciar orquestrador ao abrir"
                                          IsChecked="True"/>

                                <Button Content="Aplicar configurações"
                                        Style="{StaticResource BtnPrimary}"
                                        Margin="0,16,0,0" HorizontalAlignment="Left"
                                        Click="BtnApplyConfig_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── TAB: TEXTURAS ───────────────────────────────── -->
                <Grid x:Name="PanelTextures" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar da lista -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtTextureCount"
                                   Text="0 texturas detectadas"
                                   Foreground="{StaticResource BrTextSec}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Restaurar todas"
                                Style="{StaticResource BtnDanger}"
                                Click="BtnRestoreAll_Click"/>
                        <Button Grid.Column="3" Content="Atualizar"
                                Style="{StaticResource BtnSecondary}"
                                Click="BtnRefreshTextures_Click"/>
                    </Grid>

                    <!-- Lista de texturas -->
                    <Border Grid.Row="1" Background="{StaticResource BrBgCard}"
                            CornerRadius="10">
                        <ListView x:Name="ListTextures"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource BrTextPrimary}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Nome" Width="200"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Resolução" Width="110"
                                                    DisplayMemberBinding="{Binding Resolution}"/>
                                    <GridViewColumn Header="Tamanho" Width="90"
                                                    DisplayMemberBinding="{Binding SizeMB}"/>
                                    <GridViewColumn Header="Prioridade" Width="90"
                                                    DisplayMemberBinding="{Binding Priority}"/>
                                    <GridViewColumn Header="Compressão" Width="110"
                                                    DisplayMemberBinding="{Binding Compression}"/>
                                    <GridViewColumn Header="Economia" Width="90"
                                                    DisplayMemberBinding="{Binding SavedMB}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>

                <!-- ── TAB: GRÁFICO ────────────────────────────────── -->
                <Border x:Name="PanelGraph" Grid.Row="1"
                        Background="{StaticResource BrBgCard}"
                        CornerRadius="10" Padding="16"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="USO DE VRAM — ÚLTIMOS 60 SEGUNDOS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,12"/>
                        <lvc:CartesianChart x:Name="VRAMChart" Grid.Row="1"
                                            Series="{Binding ChartSeries}"
                                            XAxes="{Binding XAxes}"
                                            YAxes="{Binding YAxes}"/>
                    </Grid>
                </Border>

                <!-- ── TAB: LOG ────────────────────────────────────── -->
                <Border x:Name="PanelLog" Grid.Row="1"
                        Background="{StaticResource BrBgCard}"
                        CornerRadius="10" Padding="12"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="LOG EM TEMPO REAL" FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrTextSec}"/>
                            <Button Content="Limpar" HorizontalAlignment="Right"
                                    Style="{StaticResource BtnSecondary}"
                                    Padding="12,4"
                                    Click="BtnClearLog_Click"/>
                        </Grid>
                        <TextBox x:Name="TxtLog" Grid.Row="1"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource BrTextPrimary}"/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             STATUS BAR
        ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BrBgPanel}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatusBar"
                           Text="Pronto. Inicie o orquestrador e injete a DLL no jogo."
                           Foreground="{StaticResource BrTextSec}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtClock"
                           Grid.Column="1"
                           Foreground="{StaticResource BrTextSec}"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
