<Application x:Class="VRAMOptimizer.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Paleta de cores ─────────────────────────────────────────── -->
        <Color x:Key="BgDark">#FF0F1117</Color>
        <Color x:Key="BgPanel">#FF1A1D27</Color>
        <Color x:Key="BgCard">#FF222636</Color>
        <Color x:Key="BgHover">#FF2C3147</Color>
        <Color x:Key="Accent">#FF4F8EF7</Color>
        <Color x:Key="AccentHover">#FF6BA3FF</Color>
        <Color x:Key="ColorOk">#FF3DD68C</Color>
        <Color x:Key="ColorWarn">#FFFFC107</Color>
        <Color x:Key="ColorCrit">#FFFF5252</Color>
        <Color x:Key="TextPrimary">#FFEEF0F8</Color>
        <Color x:Key="TextSecondary">#FF8A90A8</Color>
        <Color x:Key="Border">#FF2E3350</Color>

        <SolidColorBrush x:Key="BrBgDark"      Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BrBgPanel"     Color="{StaticResource BgPanel}"/>
        <SolidColorBrush x:Key="BrBgCard"      Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BrAccent"      Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="BrOk"          Color="{StaticResource ColorOk}"/>
        <SolidColorBrush x:Key="BrWarn"        Color="{StaticResource ColorWarn}"/>
        <SolidColorBrush x:Key="BrCrit"        Color="{StaticResource ColorCrit}"/>
        <SolidColorBrush x:Key="BrTextPrimary" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="BrTextSec"     Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BrBorder"      Color="{StaticResource Border}"/>

        <!-- ── Estilo base de texto ────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- ── Botão padrão ────────────────────────────────────────────── -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BrAccent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentHover}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de perigo (ejetar / restaurar) -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background">
                <Setter.Value><SolidColorBrush Color="{StaticResource ColorCrit}"/></Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário (neutro) -->
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource BrBgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
        </Style>

        <!-- ── TextBox ─────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource BrBgDark}"/>
            <Setter Property="Foreground"       Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="CaretBrush"       Value="{StaticResource BrAccent}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox ───────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BrBgDark}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <!-- ── Slider ─────────────────────────────────────────────────── -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
        </Style>

        <!-- ── CheckBox ───────────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- ── ScrollBar ──────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource BrBgPanel}"/>
        </Style>

    </Application.Resources>
</Application>
